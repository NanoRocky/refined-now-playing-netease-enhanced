{
  "name": "refined-now-playing-netease-enhanced",
  "version": "0.2.1",
  "description": "RefinedNowPlaying Enhanced",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "build:dev": "tsc --noEmit && vite build --mode development",
    "watch": "vite build --watch",
    "serve": "vite",
    "format": "prettier --write ./src/",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "type-check": "tsc --noEmit",
    "package-update": "npm-check-updates -u && pnpm update --latest --save"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@material/material-color-utilities": "^0.4.0",
    "@mui/material": "^7.3.9",
    "colorthief": "^3.3.1",
    "compare-versions": "^6.1.1",
    "fast-average-color": "^9.5.1",
    "lodash": "^4.17.23",
    "path-browserify": "^1.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.27.4",
    "npm-check-updates": "^20.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "sass": "^1.98.0",
    "terser": "^5.46.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-css-injected-by-js": "^4.0.1"
  }
}