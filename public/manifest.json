{
    "manifest_version": 1,
    "name": "RefinedNowPlaying Enhanced",
    "slug": "RefinedNowPlaying-Enhanced",
    "author": "NanoRocky, Pizero, LaoShui, solstice23",
    "author_links": [
        "https://github.com/NanoRocky",
        "https://github.com/pizeroLOL",
        "https://github.com/laoshuikaixue",
        "https://github.com/solstice23"
    ],
    "description": "重新设计的正在播放页面和歌词",
    "preview": "preview.webp",
    "version": "0.2.1",
    "branch": "main",
    "type": "extension",
    "ncm3-compatible": true,
    "requirements": [],
    "loadAfter": [
        "MaterialYouTheme",
        "LibFrontendPlay",
        "SimpleAudioVisualizer"
    ],
    "incompatible": [
        "Apple-Musiclike-lyrics"
    ],
    "betterncm_version": ">=1.0.0",
    "injects": {
        "Main": [
            {
                "file": "main.js"
            }
        ]
    },
    "hijacks": {
        ">= 2.10.4": {
            "orpheus://orpheus/pub/core": {
                "type": "replace",
                "from": "function(t,i,e,r,n,a){var o;if(((this.U()||C).from||C).id==t)",
                "to": "async function(t,i,e,r,n,a){;i='online';window.onProcessLyrics&&(a=(await onProcessLyrics(a,e)));var o;if(((this.U()||C).from||C).id==t)"
            }
        },
        ">= 3.0.0": {
            "orpheus://orpheus/pub/core": {
                "type": "replace",
                "from": "function(t,i,e,r,n,a){var o;if(((this.U()||C).from||C).id==t)",
                "to": "async function(t,i,e,r,n,a){;i='online';window.onProcessLyrics&&(a=(await onProcessLyrics(a,e)));var o;if(((this.U()||C).from||C).id==t)"
            }
        }
    }
}